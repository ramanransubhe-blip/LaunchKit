{
  "name": "devlaunchkit",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade open-source SaaS starter kit foundation",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mjs}\"",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "setup": "tsx scripts/setup.ts",
    "clean": "tsx scripts/clean.ts",
    "verify": "tsx scripts/verify.ts",
    "doctor": "tsx packages/cli/src/index.ts doctor",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  }
}
