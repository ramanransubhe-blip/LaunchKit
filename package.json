{
  "name": "devlaunchkit",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade open-source SaaS starter kit foundation",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md,mjs}\"",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "bootstrap": "tsx scripts/bootstrap.ts",
    "setup": "tsx scripts/setup.ts",
    "clean": "tsx scripts/clean.ts",
    "verify": "tsx scripts/verify.ts",
    "doctor": "tsx packages/cli/src/index.ts doctor",
    "prepare": "husky"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "esbuild": "^0.25.0"
  },
  "pnpm": {
    "overrides": {
      "postcss": "^8.5.10",
      "esbuild": "^0.25.0"
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.39.5",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "eslint": "^9.39.5",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0"
  }
}
