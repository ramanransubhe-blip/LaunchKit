{
  "name": "@devlaunchkit/example-internal-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Internal operations dashboard with real-time metrics, Redis caching, background jobs, and structured logging",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "tsx src/workers/aggregator.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@devlaunchkit/analytics": "workspace:*",
    "@devlaunchkit/cache": "workspace:*",
    "@devlaunchkit/database": "workspace:*",
    "@devlaunchkit/logger": "workspace:*",
    "@devlaunchkit/observability": "workspace:*",
    "@devlaunchkit/queue": "workspace:*",
    "@devlaunchkit/env": "workspace:*",
    "express": "^4.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
