{
  "name": "@devlaunchkit/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src tests --ext .ts,.tsx",
    "test": "tsx --test tests/run.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "tsx ../../scripts/clean.ts"
  },
  "dependencies": {
    "@devlaunchkit/errors": "workspace:*",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}